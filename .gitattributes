# Treat finance fixture spreadsheets as opaque binary so git doesn't try to
# diff them and CI doesn't surface their contents in PR review.
*.xlsx binary
*.xlsb binary
*.xlsm binary
*.parquet binary

# Knowledge-base index regenerated by scripts/build_knowledge_index.py.
# Mark as generated so review tooling collapses by default.
knowledge/index.yaml linguist-generated=true

# Sample task outputs are derived artifacts.
tasks/*/outputs/**/*.json linguist-generated=true
tasks/*/outputs/**/*.parquet linguist-generated=true
