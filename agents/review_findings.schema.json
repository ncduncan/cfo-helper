{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cfo-helper/agents/review_findings.schema.json",
  "title": "Reviewer Findings",
  "description": "Reviewer's independent audit output. BLOCKER/MAJOR findings must be resolved before Coordinator finalizes.",
  "type": "object",
  "required": ["agent", "period", "produced_at", "sign_off", "findings", "independent_recomputations"],
  "additionalProperties": false,
  "properties": {
    "agent": { "const": "reviewer" },
    "period": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
    "produced_at": { "type": "string", "format": "date-time" },
    "sign_off": {
      "type": "string",
      "enum": ["signed_off", "rejected", "pending"],
      "description": "signed_off requires zero open BLOCKER/MAJOR findings"
    },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "title", "description", "target_claim"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["BLOCKER", "MAJOR", "MINOR", "INFO"]
          },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "target_claim": {
            "type": "string",
            "description": "Which upstream claim id this finding pertains to (or 'global' for systemic issues)"
          },
          "expected": { "type": ["number", "string", "null"] },
          "actual": { "type": ["number", "string", "null"] },
          "delta": { "type": ["number", "string", "null"] },
          "evidence_path": { "type": "string" },
          "remediation": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["open", "acknowledged", "resolved", "waived"],
            "default": "open"
          }
        }
      }
    },
    "independent_recomputations": {
      "type": "array",
      "description": "Headline numbers Reviewer recomputed from source. Each compares Reviewer's value to the upstream claim's value.",
      "items": {
        "type": "object",
        "required": ["upstream_claim_id", "upstream_value", "reviewer_value", "match"],
        "additionalProperties": false,
        "properties": {
          "upstream_claim_id": { "type": "string" },
          "upstream_value": { "type": ["number", "string"] },
          "reviewer_value": { "type": ["number", "string"] },
          "delta": { "type": ["number", "string"] },
          "tolerance": { "type": ["number", "string"] },
          "match": { "type": "boolean" },
          "method": { "type": "string", "description": "How Reviewer derived the value (script + inputs)" }
        }
      }
    },
    "provenance_audit": {
      "type": "object",
      "description": "Sample-based check that every numeric claim in the final pack traces to source.",
      "additionalProperties": false,
      "properties": {
        "sample_size": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "failures": {
          "type": "array",
          "items": { "type": "string", "description": "Claim ids that failed provenance check" }
        }
      }
    }
  }
}
